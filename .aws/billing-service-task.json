{
    "containerDefinitions": [
        {
            "name": "billing-service",
            "image": "459224529582.dkr.ecr.us-east-1.amazonaws.com/billing-engine@sha256:7621d0bbc47dac054d255541287bdd49fa8500659d8a4ed57ac38750152c59c1",
            "command": ["node", "dist/src/server.js"],
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp",
                    "name": "billing-api-8000-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                { "name": "RUN_MIGRATIONS", "value": "true" }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "DATABASE_URL",
                    "valueFrom": "/billing/DATABASE_URL"
                },
                {
                    "name": "AWS_REGION",
                    "valueFrom": "/billing/AWS_REGION"
                },
                {
                    "name": "PORT",
                    "valueFrom": "/billing/PORT"
                },
                {
                    "name": "AWS_ACCESS_KEY",
                    "valueFrom": "/billing/AWS_ACCESS_KEY"
                },
                {
                    "name": "AWS_SECRET_KEY",
                    "valueFrom": "/billing/AWS_SECRET_KEY"
                },
                {
                    "name": "SQS_QUEUE_URL",
                    "valueFrom": "/billing/SQS_QUEUE_URL"
                },
                {
                    "name": "REDIS_HOST",
                    "valueFrom": "/billing/REDIS_HOST"
                },
                {
                    "name": "REDIS_PORT",
                    "valueFrom": "/billing/REDIS_PORT"
                }
            ],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/billing-api-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "billing-api-task",
    "executionRoleArn": "arn:aws:iam::459224529582:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "enableFaultInjection": false
}
