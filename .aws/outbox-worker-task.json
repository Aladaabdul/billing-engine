{
    "containerDefinitions": [
        {
            "name": "outbox-worker",
            "image": "459224529582.dkr.ecr.us-east-1.amazonaws.com/billing-engine@sha256:ed1ef16a23f188ff6982934f8dcd23339305936ff11d13c101db397dd568ddaf",
            "command": ["node", "dist/src/workers/outbox.worker.js"],
            "cpu": 0,
            "portMappings": [],
            "essential": true,
            "environment": [
                { 
                    "name": "RUN_MIGRATIONS", 
                    "value": "false" 
                },
                {
                    "name": "NODE_TLS_REJECT_UNAUTHORIZED",
                    "value": "0"
                }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "DATABASE_URL",
                    "valueFrom": "/billing/DATABASE_URL"
                },
                {
                    "name": "AWS_REGION",
                    "valueFrom": "/billing/AWS_REGION"
                },
                {
                    "name": "PORT",
                    "valueFrom": "/billing/PORT"
                },
                {
                    "name": "AWS_ACCESS_KEY",
                    "valueFrom": "/billing/AWS_ACCESS_KEY"
                },
                {
                    "name": "AWS_SECRET_KEY",
                    "valueFrom": "/billing/AWS_SECRET_KEY"
                },
                {
                    "name": "SQS_QUEUE_URL",
                    "valueFrom": "/billing/SQS_QUEUE_URL"
                },
                {
                    "name": "REDIS_HOST",
                    "valueFrom": "/billing/REDIS_HOST"
                },
                {
                    "name": "REDIS_PORT",
                    "valueFrom": "/billing/REDIS_PORT"
                }
            ],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/outbox-worker-task",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "outbox-worker-task",
    "taskRoleArn": "arn:aws:iam::459224529582:role/ecsTaskExecutionRole",
    "executionRoleArn": "arn:aws:iam::459224529582:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "revision": 1,
    "volumes": [],
    "status": "ACTIVE",
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024"
}
